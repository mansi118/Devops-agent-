# ============================================================
# Ops NEop — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# Required
ANTHROPIC_API_KEY=sk-ant-...
GITHUB_TOKEN=ghp_...
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# Optional — Stakpak
STAKPAK_API_KEY=sk-...

# Optional — Convex (Context Vault)
CONVEX_DEPLOYMENT_URL=https://...convex.cloud
CONVEX_API_KEY=...

# Optional — External Services
SNYK_API_TOKEN=...
FIREFLIES_API_KEY=...
TF_API_TOKEN=...
GRAFANA_API_KEY=...
GRAFANA_PASSWORD=admin
NEOS_INTERNAL_TOKEN=...

# Optional — n8n
N8N_URL=https://n8n.neuraledge.in
N8N_API_KEY=...

# Slack Channels
APPROVAL_CHANNEL=#ops-approvals
DEPLOY_CHANNEL=#deployments
METRICS_CHANNEL=#eng-metrics

# Allowed Approvers (comma-separated Slack user IDs)
ALLOWED_APPROVERS=
