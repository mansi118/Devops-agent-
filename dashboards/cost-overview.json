{
  "dashboard": {
    "title": "Ops NEop — Cost Overview",
    "uid": "ops-neop-cost",
    "tags": ["ops-neop", "cost"],
    "timezone": "Asia/Kolkata",
    "refresh": "1h",
    "panels": [
      {
        "id": 1, "title": "Total Monthly AWS Spend (INR)", "type": "stat",
        "gridPos": { "x": 0, "y": 0, "w": 8, "h": 6 },
        "targets": [{ "expr": "ops_aws_monthly_spend_inr" }],
        "fieldConfig": { "defaults": { "unit": "currencyINR" } }
      },
      {
        "id": 2, "title": "Idle Resources", "type": "stat",
        "gridPos": { "x": 8, "y": 0, "w": 8, "h": 6 },
        "targets": [{ "expr": "ops_idle_resources_count" }],
        "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 3, "color": "yellow" }, { "value": 5, "color": "red" }] } } }
      },
      {
        "id": 3, "title": "Savings Identified (INR/month)", "type": "stat",
        "gridPos": { "x": 16, "y": 0, "w": 8, "h": 6 },
        "targets": [{ "expr": "ops_savings_identified_inr" }],
        "fieldConfig": { "defaults": { "unit": "currencyINR" } }
      },
      {
        "id": 4, "title": "Spend by Service", "type": "piechart",
        "gridPos": { "x": 0, "y": 6, "w": 12, "h": 10 },
        "targets": [{ "expr": "ops_aws_spend_by_service", "legendFormat": "{{service}}" }]
      },
      {
        "id": 5, "title": "Cost Trend (30-day)", "type": "timeseries",
        "gridPos": { "x": 12, "y": 6, "w": 12, "h": 10 },
        "targets": [{ "expr": "ops_aws_daily_spend_inr", "legendFormat": "Daily Spend" }]
      },
      {
        "id": 6, "title": "Cost Per Deployment (INR)", "type": "timeseries",
        "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
        "targets": [{ "expr": "ops_cost_per_deployment_inr", "legendFormat": "Cost/Deploy" }]
      }
    ]
  }
}
